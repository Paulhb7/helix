# Model provider: "api" (Google AI Studio) or "local" (Ollama)
MODEL_PROVIDER=local

# Google AI Studio (Gemma via Gemini API) — get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMMA_API_MODEL=gemma-4-31b-it
GEMMA_API_MODEL_FAST=gemma-4-26b-a4b-it

# Local Ollama (used when MODEL_PROVIDER=local)
OLLAMA_API_BASE=http://localhost:11434
OLLAMA_MODEL=gemma4:e4b
OLLAMA_MODEL_FAST=gemma4:e2b

# Local audio transcription model (HuggingFace transformers, ~16 GB on disk).
# Used only for TikTok ingestion. Requires `huggingface-cli login` with the
# Gemma license accepted on https://huggingface.co/google/gemma-4-E4B-it
GEMMA_AUDIO_MODEL=google/gemma-4-E4B-it

# Optional: Google Fact Check Tools API key
# https://developers.google.com/fact-check/tools/api/reference/rest/v1alpha1/claims/search
GOOGLE_FACTCHECK_API_KEY=

# Optional: NCBI E-utils key (raises rate limit from 3 to 10 req/s)
NCBI_API_KEY=

# Polite identifier for NCBI requests
BEACON_USER_AGENT=Beacon/0.0.1 (research prototype)
